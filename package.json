{
  "name": "openbrand",
  "version": "0.2.3",
  "description": "Extract brand assets (logos, colors, backdrops) from any website URL",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "src/"
  ],
  "license": "MIT",
  "homepage": "https://openbrand.sh",
  "repository": {
    "type": "git",
    "url": "https://github.com/tight-studio/openbrand.git"
  },
  "keywords": [
    "brand",
    "logo",
    "colors",
    "scraper",
    "extraction"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "build:pkg": "tsup",
    "test": "bun test integration_test/"
  },
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.1",
    "@types/probe-image-size": "^7.2.5",
    "cheerio": "^1.2.0",
    "probe-image-size": "^7.2.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
